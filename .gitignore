# This .gitignore is appropriate for repositories deployed to GitHub Pages and using
# a Gemfile as specified at https://github.com/github/pages-gem#conventional

# Basic Jekyll gitignores (synchronize to Jekyll.gitignore)
_site/
.sass-cache/
.jekyll-cache/
.jekyll-metadata

# Additional Ruby/bundler ignore for when you run: bundle install
/vendor

# Specific ignore for GitHub Pages
# GitHub Pages will always use its own deployed version of pages-gem 
# This means GitHub Pages will NOT use your Gemfile.lock and therefore it is
# counterproductive to check this file into the repository.
# Details at https://github.com/github/pages-gem/issues/768
Gemfile.lock

# Claude Code local settings
.claude/settings.local.json

# Environment files (contain secrets)
.env
.env.local
.env.*.local

# Cloned repo cache (used by update-all.sh)
.repo-cache/

# Extracted data (working files, regenerated by extract)
reports/

# Pending batches (generated by scripts/pending.js, ephemeral)
pending/
pending-batch-*.json

# Note: processed/*/batches/ IS tracked - contains AI-analyzed commits (source of truth)
# Note: processed/*/manifest.json IS tracked - tracks which SHAs have been processed

# Node modules
node_modules/

# Vite build output
dist/

# Generated at build time (scripts/write-build-version.mjs)
dashboard/public/version.json

# Playwright test artifacts (reports, traces, videos, generated screenshots).
# Screenshot BASELINES live in dashboard/e2e/visual/__screenshots__/ and
# are committed — the patterns below only exclude transient output.
/test-results/
/playwright-report/
/playwright/.cache/
# Any screenshot diff output (only produced on failing visual tests).
**/*-actual.png
**/*-diff.png
